# Cloudflare Pages response headers.
# Spec: https://developers.cloudflare.com/pages/configuration/headers/

# Global security headers — applied to every response.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: blob: https://*.basemaps.cartocdn.com; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://docs.google.com; object-src 'none'; upgrade-insecure-requests

# HTML files: short cache so updates ship fast.
/*.html
  Cache-Control: public, max-age=300, must-revalidate

# Service worker MUST be served with no-cache so updates propagate.
# Browsers ignore the SW cache name bump if the SW script itself is cached.
/sw.js
  Cache-Control: public, max-age=0, must-revalidate

# Manifest, robots, sitemap, llms.txt: short cache.
/manifest.json
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=3600
/sitemap.xml
  Cache-Control: public, max-age=3600
/llms.txt
  Cache-Control: public, max-age=3600

# Dataset JS (non-hashed filename, changes on data refresh): revalidate often so
# updates ship without a stale app. Must precede the immutable /data/* rule.
/data/exhibit-data.js
  Cache-Control: public, max-age=600, must-revalidate

# Static data files: long cache + immutable hint.
/data/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts: content-hashed filenames -> safe to cache immutably.
/fonts/*.woff2
  Cache-Control: public, max-age=31536000, immutable
/fonts/fonts.css
  Cache-Control: public, max-age=86400

# Self-hosted Leaflet (pinned at 1.9.4) -> safe to cache immutably.
/vendor/*
  Cache-Control: public, max-age=31536000, immutable

# Icons / images: long cache.
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.webp
  Cache-Control: public, max-age=31536000, immutable
/*.ico
  Cache-Control: public, max-age=31536000, immutable
