# Cloudflare Pages response headers.
# Spec: https://developers.cloudflare.com/pages/configuration/headers/

# Global security headers — applied to every response.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# HTML files: short cache so updates ship fast.
/*.html
  Cache-Control: public, max-age=300, must-revalidate

# Service worker MUST be served with no-cache so updates propagate.
# Browsers ignore the SW cache name bump if the SW script itself is cached.
/sw.js
  Cache-Control: public, max-age=0, must-revalidate

# Manifest, robots, sitemap, llms.txt: short cache.
/manifest.json
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=3600
/sitemap.xml
  Cache-Control: public, max-age=3600
/llms.txt
  Cache-Control: public, max-age=3600

# Static data files: long cache + immutable hint.
/data/*
  Cache-Control: public, max-age=31536000, immutable

# Icons / images: long cache.
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.webp
  Cache-Control: public, max-age=31536000, immutable
/*.ico
  Cache-Control: public, max-age=31536000, immutable
